/* pages.css — styles communs aux pages statiques */

.back-link {
  color: #1D9E75;
  text-decoration: none;
  font-size: 18px;
  display: flex;
  align-items: center;
  padding: 2px;
}

.page-hero {
  background: #E1F5EE;
  border-bottom: 1px solid #9FE1CB;
  padding: 24px 16px 20px;
  text-align: center;
}
.page-hero-icon { font-size: 36px; color: #1D9E75; display: block; margin-bottom: 8px; }
.page-hero-title { font-size: 20px; font-weight: 600; color: #085041; line-height: 1.3; margin-bottom: 4px; }
.page-hero-sub   { font-size: 13px; color: #1D9E75; }

.page-section {
  padding: 16px 16px 4px;
  border-bottom: 1px solid #eee;
}
.page-section:last-child { border-bottom: none; }
.page-section h2 {
  font-size: 13px;
  font-weight: 600;
  color: #999;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-bottom: 10px;
}
.page-section p {
  font-size: 13px;
  color: #444;
  line-height: 1.6;
  margin-bottom: 10px;
}
.page-note {
  font-size: 12px !important;
  color: #888 !important;
  font-style: italic;
}

.icon-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
.icon-item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13px;
  color: #444;
  padding: 4px 0;
}
.icon-item i  { color: #1D9E75; font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.icon-item a  { color: #1D9E75; text-decoration: none; }

.btn-primary-full {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 11px;
  font-size: 13px;
  font-weight: 600;
  background: #1D9E75;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  margin-bottom: 12px;
}
.btn-outline-full {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 11px;
  font-size: 13px;
  font-weight: 500;
  background: transparent;
  color: #1D9E75;
  border: 1px solid #1D9E75;
  border-radius: 8px;
  cursor: pointer;
  text-decoration: none;
  margin-bottom: 12px;
}

.bureau-list  { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
.bureau-item  { display: flex; align-items: center; gap: 12px; padding: 8px 0; border-bottom: 1px solid #f0f0ec; }
.bureau-item:last-child { border-bottom: none; }
.bureau-av    { width: 36px; height: 36px; border-radius: 50%; background: #E1F5EE; display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 600; color: #0F6E56; flex-shrink: 0; }
.bureau-name  { font-size: 13px; font-weight: 500; color: #1a1a18; }
.bureau-role  { font-size: 11px; color: #888; }

.tarif-grid   { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 12px; }
.tarif-card   { background: #f5f5f0; border-radius: 8px; padding: 12px 8px; text-align: center; }
.tarif-prix   { font-size: 20px; font-weight: 600; color: #1D9E75; }
.tarif-label  { font-size: 11px; color: #888; margin-top: 2px; }

.steps-list   { display: flex; flex-direction: column; gap: 12px; margin-bottom: 12px; }
.step-item    { display: flex; gap: 12px; align-items: flex-start; }
.step-num     { width: 26px; height: 26px; border-radius: 50%; background: #1D9E75; color: #fff; font-size: 12px; font-weight: 600; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px; }
.step-title   { font-size: 13px; font-weight: 500; color: #1a1a18; margin-bottom: 2px; }
.step-desc    { font-size: 12px; color: #666; line-height: 1.5; }

.page-footer  { padding: 16px; }
