/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; -webkit-text-size-adjust: 100%; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  background: #f5f5f0;
  color: #1a1a18;
  line-height: 1.5;
  min-height: 100dvh;
}

/* ===== LAYOUT APP ===== */
#app {
  max-width: 480px;
  margin: 0 auto;
  background: #fff;
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ===== TOPBAR ===== */
#topbar {
  background: #fff;
  border-bottom: 1px solid #e8e8e4;
  padding: 12px 16px 10px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  position: sticky;
  top: 0;
  z-index: 10;
}
#topbar-title { font-size: 15px; font-weight: 600; color: #1a1a18; }
#topbar-sub   { font-size: 11px; color: #888; margin-top: 1px; }
#topbar-bell  { font-size: 20px; color: #aaa; cursor: pointer; }

/* ===== MAIN SCREEN ===== */
#screen { flex: 1; overflow-y: auto; overflow-x: hidden; }

/* ===== BOTTOM NAVBAR ===== */
#navbar {
  background: #fff;
  border-top: 1px solid #e8e8e4;
  display: flex;
  flex-shrink: 0;
  position: sticky;
  bottom: 0;
  z-index: 10;
}
.nav-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 8px 4px 10px;
  cursor: pointer;
  border: none;
  background: transparent;
  color: #aaa;
  font-size: 10px;
  transition: color .15s;
}
.nav-btn i    { font-size: 20px; }
.nav-btn.active { color: #1D9E75; }

/* ===== SCREENS ===== */
.screen { display: none; }
.screen.active { display: block; }

/* ===== HERO PROCHAINE RANDO ===== */
.hero {
  background: #E1F5EE;
  padding: 16px;
  border-bottom: 1px solid #9FE1CB;
}
.hero-eyebrow {
  font-size: 10px;
  font-weight: 600;
  color: #0F6E56;
  text-transform: uppercase;
  letter-spacing: .06em;
  margin-bottom: 4px;
}
.hero-title { font-size: 18px; font-weight: 600; color: #085041; line-height: 1.3; }
.hero-sub   { font-size: 12px; color: #1D9E75; margin-top: 2px; }
.hero-chips { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 10px; }
.chip {
  background: rgba(255,255,255,.75);
  border: 1px solid #5DCAA5;
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 11px;
  font-weight: 500;
  color: #085041;
}

/* ===== SECTION TITLE ===== */
.section-title {
  font-size: 11px;
  font-weight: 600;
  color: #999;
  text-transform: uppercase;
  letter-spacing: .06em;
  padding: 14px 16px 6px;
  background: #f5f5f0;
}

/* ===== RANDO CARD (liste) ===== */
.rando-card {
  background: #fff;
  border-bottom: 1px solid #eee;
  padding: 12px 16px;
  cursor: pointer;
  display: flex;
  gap: 12px;
  align-items: flex-start;
  transition: background .1s;
}
.rando-card:active { background: #f9f9f7; }
.date-col { text-align: center; min-width: 36px; flex-shrink: 0; }
.date-day  { font-size: 20px; font-weight: 600; color: #1a1a18; line-height: 1; }
.date-mon  { font-size: 10px; color: #aaa; text-transform: uppercase; }
.rando-info { flex: 1; min-width: 0; }
.rando-name {
  font-size: 13px;
  font-weight: 500;
  color: #1a1a18;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.rando-meta { font-size: 11px; color: #888; margin-top: 3px; }
.chevron    { font-size: 16px; color: #ccc; margin-top: 2px; flex-shrink: 0; }

/* ===== BADGES DIFFICULTÉ ===== */
.badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 600;
  padding: 2px 7px;
  border-radius: 10px;
}
.badge-facile    { background: #EAF3DE; color: #3B6D11; }
.badge-moyen     { background: #FAEEDA; color: #633806; }
.badge-difficile { background: #FAECE7; color: #712B13; }

/* ===== FILTRE BAR ===== */
.filtre-bar {
  display: flex;
  gap: 6px;
  padding: 10px 16px;
  overflow-x: auto;
  border-bottom: 1px solid #eee;
  background: #fff;
  scrollbar-width: none;
}
.filtre-bar::-webkit-scrollbar { display: none; }
.filtre-btn {
  white-space: nowrap;
  font-size: 11px;
  font-weight: 500;
  padding: 5px 12px;
  border-radius: 20px;
  border: 1px solid #ddd;
  background: transparent;
  color: #666;
  cursor: pointer;
  flex-shrink: 0;
  transition: all .15s;
}
.filtre-btn.on { background: #1D9E75; color: #fff; border-color: #1D9E75; }
.filtre-jour.on { background: var(--fc, #1D9E75); color: #fff; border-color: var(--fc, #1D9E75); }
.filtre-jour.on span { background: #fff !important; }
a.filtre-btn { display: inline-flex; align-items: center; }

/* ===== FICHE DÉTAIL ===== */
#detail-screen { display: none; }
#detail-screen.active { display: block; }
.detail-back {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 16px;
  font-size: 13px;
  color: #1D9E75;
  cursor: pointer;
  background: #fff;
  border-bottom: 1px solid #eee;
}
.detail-hero {
  background: #E1F5EE;
  padding: 14px 16px 12px;
  border-bottom: 1px solid #9FE1CB;
}
.detail-date  { font-size: 11px; color: #1D9E75; font-weight: 500; margin-bottom: 4px; }
.detail-title { font-size: 17px; font-weight: 600; color: #085041; line-height: 1.3; }
.stats-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  padding: 12px 16px;
  border-bottom: 1px solid #eee;
}
.stat-box    { background: #f5f5f0; border-radius: 8px; padding: 8px; text-align: center; }
.stat-val    { font-size: 17px; font-weight: 600; color: #1a1a18; }
.stat-lbl    { font-size: 10px; color: #aaa; }
.detail-rows { padding: 0 16px; }
.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 9px 0;
  border-bottom: 1px solid #f0f0ec;
  font-size: 13px;
}
.detail-row:last-child { border-bottom: none; }
.dr-label { color: #888; display: flex; align-items: center; gap: 5px; }
.dr-val   { font-weight: 500; color: #1a1a18; text-align: right; max-width: 180px; }
.pts-block { padding: 10px 16px; border-bottom: 1px solid #eee; }
.pts-title { font-size: 10px; color: #aaa; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 6px; }
.pt-pill {
  display: inline-block;
  background: #f5f5f0;
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 12px;
  color: #666;
  margin: 2px 3px 2px 0;
}
.anim-row    { display: flex; align-items: center; gap: 10px; padding: 12px 16px; border-bottom: 1px solid #eee; }
.anim-av     { width: 36px; height: 36px; border-radius: 50%; background: #E6F1FB; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; color: #0C447C; flex-shrink: 0; }
.anim-name   { font-size: 13px; font-weight: 500; color: #1a1a18; }
.anim-tel    { font-size: 12px; color: #888; }
.detail-map-btn { margin: 12px 16px 16px; width: calc(100% - 32px); }

/* ===== CARTE ===== */
.carte-wrap { width: 100%; height: calc(100dvh - 130px); display: flex; flex-direction: column; }
.carte-iframe-wrap { flex: 1; overflow: hidden; }
.carte-iframe-wrap iframe { width: 100%; height: 100%; border: none; display: block; }
.carte-footer {
  padding: 9px 16px;
  background: #fff;
  border-top: 1px solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12px;
  color: #aaa;
}
.carte-footer a { color: #1D9E75; display: flex; align-items: center; gap: 4px; text-decoration: none; }

/* ===== ESPACE ANIMATEUR (section Infos) ===== */
.animateur-gate {
  background: #FAEEDA;
  border: 1px solid #EF9F27;
  border-radius: 10px;
  margin: 14px 16px;
  padding: 14px;
}
.animateur-gate-title {
  font-size: 13px;
  font-weight: 600;
  color: #633806;
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}
.animateur-gate-sub { font-size: 12px; color: #854F0B; line-height: 1.5; margin-bottom: 10px; }
.btn-animateur {
  width: 100%;
  padding: 9px;
  font-size: 13px;
  font-weight: 500;
  background: #BA7517;
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}
.info-section { padding: 14px 16px; border-bottom: 1px solid #eee; }
.info-section h3 { font-size: 13px; font-weight: 600; color: #1a1a18; margin-bottom: 8px; }
.info-link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 0;
  font-size: 13px;
  color: #555;
  border-bottom: 1px solid #f0f0ec;
  cursor: pointer;
  text-decoration: none;
}
.info-link:last-child { border-bottom: none; }
.info-link i { color: #1D9E75; font-size: 16px; flex-shrink: 0; }

/* ===== FORMULAIRE ANIMATEUR ===== */
#form-screen { display: none; }
#form-screen.active { display: block; }
.form-topbar {
  background: #FAEEDA;
  border-bottom: 1px solid #EF9F27;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.form-topbar-badge {
  background: #BA7517;
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.form-topbar-title { font-size: 14px; font-weight: 600; color: #633806; }
.form-topbar-back  { font-size: 18px; color: #854F0B; cursor: pointer; margin-right: 4px; }
.step-bar {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 10px 16px;
  background: #fff;
  border-bottom: 1px solid #eee;
}
.step-dot { width: 8px; height: 8px; border-radius: 50%; background: #e0e0da; flex-shrink: 0; transition: all .2s; }
.step-dot.done   { background: #1D9E75; }
.step-dot.active { background: #1D9E75; width: 22px; border-radius: 4px; }
.step-label { font-size: 12px; color: #666; margin-left: 4px; }
.step-label strong { color: #1D9E75; font-weight: 600; }
.form-body { padding: 14px 16px; background: #fff; }
.field       { margin-bottom: 14px; }
.field label { display: block; font-size: 12px; font-weight: 600; color: #555; margin-bottom: 5px; }
.field input, .field select {
  width: 100%;
  padding: 8px 10px;
  font-size: 13px;
  border: 1px solid #ddd;
  border-radius: 8px;
  background: #fff;
  color: #1a1a18;
}
.field input:focus, .field select:focus { outline: none; border-color: #1D9E75; }
.field-row { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 10px; }
.diff-row  { display: flex; gap: 6px; }
.diff-btn  {
  flex: 1;
  padding: 7px 4px;
  font-size: 12px;
  font-weight: 500;
  border-radius: 8px;
  border: 1px solid #ddd;
  background: transparent;
  color: #666;
  cursor: pointer;
}
.diff-btn.sel-facile    { background: #EAF3DE; color: #3B6D11; border-color: #97C459; }
.diff-btn.sel-moyen     { background: #FAEEDA; color: #633806; border-color: #EF9F27; }
.diff-btn.sel-difficile { background: #FAECE7; color: #712B13; border-color: #F0997B; }
.covoit-row { display: flex; gap: 8px; margin-top: 2px; }
.covoit-btn {
  flex: 1;
  padding: 7px;
  font-size: 12px;
  font-weight: 500;
  border-radius: 8px;
  border: 1px solid #ddd;
  background: transparent;
  color: #666;
  cursor: pointer;
}
.covoit-btn.sel { background: #E1F5EE; color: #0F6E56; border-color: #5DCAA5; }
.pts-wrap   { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 6px; }
.pt-tag     {
  background: #f5f5f0;
  border: 1px solid #e0e0da;
  border-radius: 20px;
  padding: 3px 8px 3px 10px;
  font-size: 12px;
  color: #555;
  display: flex;
  align-items: center;
  gap: 4px;
}
.pt-tag button { background: none; border: none; cursor: pointer; color: #aaa; font-size: 15px; line-height: 1; padding: 0; }
.pt-add        { display: flex; gap: 6px; }
.pt-add input  { flex: 1; }
.pt-add button { flex-shrink: 0; padding: 6px 12px; font-size: 12px; border: 1px solid #ddd; border-radius: 8px; background: transparent; cursor: pointer; }
.err { font-size: 11px; color: #c0392b; margin-top: 4px; display: none; }
.form-footer {
  padding: 12px 16px;
  background: #fff;
  border-top: 1px solid #eee;
  display: flex;
  gap: 8px;
}
.form-footer button { flex: 1; padding: 10px; font-size: 13px; border-radius: 8px; cursor: pointer; }
.btn-primary   { background: #1D9E75; color: #fff; border: none; font-weight: 600; }
.btn-secondary { background: transparent; border: 1px solid #ddd; color: #666; }
.recap-row {
  display: flex;
  justify-content: space-between;
  padding: 7px 0;
  border-bottom: 1px solid #f0f0ec;
  font-size: 13px;
}
.recap-row:last-child { border-bottom: none; }
.recap-label { color: #888; }
.recap-val   { font-weight: 500; color: #1a1a18; text-align: right; max-width: 190px; }
.send-note {
  background: #E1F5EE;
  border-radius: 8px;
  padding: 10px 12px;
  margin-top: 12px;
  font-size: 12px;
  color: #085041;
  display: flex;
  gap: 8px;
  align-items: flex-start;
  line-height: 1.5;
}
.send-note i { font-size: 16px; color: #1D9E75; flex-shrink: 0; margin-top: 1px; }
.success-screen { text-align: center; padding: 32px 20px; }
.success-screen i { font-size: 48px; color: #1D9E75; display: block; margin-bottom: 12px; }
.success-title { font-size: 16px; font-weight: 600; color: #1a1a18; margin-bottom: 6px; }
.success-sub   { font-size: 13px; color: #666; line-height: 1.6; margin-bottom: 16px; }
.workflow-box {
  background: #f5f5f0;
  border-radius: 8px;
  padding: 12px;
  font-size: 12px;
  color: #555;
  text-align: left;
  line-height: 1.8;
}
.workflow-box strong { color: #1a1a18; display: block; margin-bottom: 4px; }

/* ===== SCROLLBAR ===== */
#screen::-webkit-scrollbar { width: 4px; }
#screen::-webkit-scrollbar-thumb { background: #e0e0da; border-radius: 2px; }


/* ===== TOPBAR LOGO ===== */
#topbar { min-height: 58px; }
#topbar-logo { filter: drop-shadow(0 1px 2px rgba(0,0,0,.08)); }

/* ===== HERO SANS LOGO (bandeau photo séparé) ===== */
.hero { padding: 12px 0 14px; }


.hero .hero-eyebrow { padding: 0 16px; }
.hero .hero-title   { padding: 0 16px; }
.hero .hero-sub     { padding: 0 16px; }
.hero .hero-chips   { padding: 0 16px; }

/* ===== BANNIÈRES WEBMASTER ===== */
.banniere {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 11px 16px;
  font-size: 13px;
  line-height: 1.5;
  border-bottom: 1px solid transparent;
  animation: slidein .25s ease;
}
@keyframes slidein {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}
.banniere i { font-size: 17px; flex-shrink: 0; margin-top: 1px; }
.banniere-info      { background: #E6F1FB; border-color: #A8CDEF; color: #0C2E5A; }
.banniere-info i    { color: #0C447C; }
.banniere-alerte    { background: #FAECE7; border-color: #F0997B; color: #712B13; }
.banniere-alerte i  { color: #C0391B; }
.banniere-evenement { background: #F0EBF9; border-color: #C39FE8; color: #3A1060; }
.banniere-evenement i { color: #6B2FAD; }
.banniere-succes    { background: #E1F5EE; border-color: #9FE1CB; color: #085041; }
.banniere-succes i  { color: #1D9E75; }
.banniere-content   { flex: 1; }
.banniere-lien {
  display: inline-block;
  margin-top: 5px;
  font-size: 12px;
  font-weight: 600;
  text-decoration: underline;
  cursor: pointer;
}
.banniere-close {
  background: none;
  border: none;
  cursor: pointer;
  font-size: 16px;
  opacity: .5;
  padding: 0;
  flex-shrink: 0;
  color: inherit;
  line-height: 1;
}
.banniere-close:hover { opacity: 1; }
